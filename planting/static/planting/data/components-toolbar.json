{
  "toolbar_id": "main-tool-palette",
  "label": "Tool Palette",
  "description": "Left-side vertical tool palette for the editor viewport",
  "defaultMode": "simple",
  "tools": [
    {
      "group": "selection",
      "label": "Selection",
      "tools": [
        {
          "id": "select",
          "label": "Select / Point to Click",
          "icon": "svg:select",
          "shortcut": "V",
          "modes": ["simple", "advanced"],
          "options": []
        }
      ]
    },
    {
      "group": "area-selection",
      "label": "Area Selection",
      "tools": [
        { "id": "rect-select", "label": "Rectangle Select", "icon": "svg:rect-select", "shortcut": "M", "options": ["selection-mode"] },
        { "id": "circular-select", "label": "Circular Select", "icon": "svg:circular-select", "options": ["selection-mode"] }
      ]
    },
    {
      "group": "marquee",
      "label": "Marquee",
      "tools": [
        { "id": "marquee", "label": "Marquee Selection", "icon": "svg:marquee", "shortcut": "L", "options": ["selection-mode"] },
        { "id": "polygon-marquee", "label": "Polygon Selection", "icon": "bi-pentagon", "options": ["selection-mode"] }
      ]
    },
    {
      "group": "boolean",
      "label": "Boolean Operations",
      "tools": [
        { "id": "merge-shapes", "label": "Merge Shapes - Combine Shapes", "icon": "svg:join", "options": ["join-mode"] },
        { "id": "weld-vertices", "label": "Weld Vertices", "icon": "svg:weld-vertices", "options": ["weld-threshold"] }
      ]
    },
    {
      "group": "shapes",
      "label": "Shapes",
      "tools": [
        { "id": "shape-square", "label": "Square", "icon": "svg:square", "shortcut": "U", "addComponent": { "action": "add-square", "label": "Add Square", "group": "shapes", "order": 1 }, "options": ["shape-mode", "fill-type", "fill-colour", "fill-icon"] },
        { "id": "shape-rectangle", "label": "Rectangle", "icon": "svg:rectangle", "addComponent": { "action": "add-rectangle", "label": "Add Rectangle", "group": "shapes", "order": 2 }, "options": ["shape-mode", "fill-type", "fill-colour", "fill-icon"] },
        { "id": "shape-circle", "label": "Circle", "icon": "svg:circle", "addComponent": { "action": "add-circle", "label": "Add Circle", "group": "shapes", "order": 3 }, "options": ["shape-mode", "circle-radii", "fill-type", "fill-colour", "fill-icon"] },
        { "id": "shape-polygon", "label": "Polygon", "icon": "svg:polygon", "options": ["shape-mode", "polygon-sides", "fill-type", "fill-colour", "fill-icon"] }
      ]
    },
    {
      "group": "eraser",
      "label": "Eraser",
      "tools": [
        { "id": "eraser", "label": "Eraser", "icon": "bi-eraser", "modes": ["simple", "advanced"], "options": ["eraser-size", "eraser-mode"] }
      ]
    },
    {
      "group": "fill",
      "label": "Fill",
      "tools": [
        { "id": "fill", "label": "Fill Tool - Paint shapes", "icon": "bi-paint-bucket", "shortcut": "G", "options": ["fill-colour", "fill-tolerance"] }
      ]
    },
    {
      "group": "annotation",
      "label": "Annotation / Text",
      "tools": [
        { "id": "annotation", "label": "Annotation / Text", "icon": "bi-chat-square-text-fill", "shortcut": "T", "addComponent": { "action": "add-annotation", "label": "Add Annotation", "group": "objects", "order": 3 }, "options": ["annotation-title", "annotation-description", "annotation-icon", "annotation-upload"] }
      ]
    },
    {
      "group": "picture",
      "label": "Picture",
      "tools": [
        { "id": "picture", "label": "Picture - Place image on map", "icon": "bi-image", "addComponent": { "action": "add-image", "label": "Add Image", "group": "objects", "order": 2 }, "options": ["picture-upload", "picture-size"] }
      ]
    },
    {
      "group": "icon",
      "label": "Icon",
      "tools": [
        { "id": "icon", "label": "Icon - Place icon on map", "icon": "bi-info-circle", "addComponent": { "action": "add-icon", "label": "Add Icon", "group": "objects", "order": 1 }, "options": ["icon-type", "icon-size"] }
      ]
    },
    {
      "group": "line",
      "label": "Line Tools",
      "tools": [
        { "id": "line", "label": "Straight Line", "icon": "bi-pencil", "shortcut": "P", "modes": ["simple", "advanced"], "options": ["line-mode", "line-spacing", "line-type", "line-shape", "fill-type", "fill-colour", "fill-icon"] },
        { "id": "line-curved", "label": "Curved Line / Bezier", "icon": "bi-bezier2", "options": ["line-mode", "line-spacing", "bezier-handles", "line-shape", "fill-type", "fill-colour", "fill-icon"] }
      ]
    },
    {
      "group": "navigation",
      "label": "Navigation",
      "tools": [
        { "id": "hand", "label": "Hand / Pan", "icon": "bi-hand-index", "shortcut": "H", "options": [] }
      ]
    },
    {
      "group": "magnification",
      "label": "Magnification",
      "tools": [
        { "id": "magnify", "label": "Magnification / Zoom", "icon": "bi-search", "shortcut": "Z" }
      ]
    }
  ],
  "option_definitions": {
    "shape-mode": {
      "label": "Mode",
      "type": "select",
      "values": [
        {"value": "annotation", "label": "Annotation"},
        {"value": "inclusion", "label": "Inclusion Zone"},
        {"value": "exclusion", "label": "Exclusion Zone"}
      ],
      "default": "annotation"
    },
    "fill-type": {
      "label": "Fill Type",
      "type": "select",
      "values": [
        {"value": "solid", "label": "Solid"},
        {"value": "hatched", "label": "Hatched"},
        {"value": "dotted", "label": "Dotted"},
        {"value": "none", "label": "None / Outline Only"}
      ],
      "default": "solid"
    },
    "fill-colour": {
      "label": "Fill Colour",
      "type": "color",
      "default": "#4CAF50"
    },
    "selection-mode": {
      "label": "Selection Mode",
      "type": "select",
      "values": [
        {"value": "new", "label": "New Selection"},
        {"value": "add", "label": "Add to Selection"},
        {"value": "subtract", "label": "Subtract from Selection"},
        {"value": "intersect", "label": "Intersect with Selection"}
      ],
      "default": "new"
    }
  }
}
