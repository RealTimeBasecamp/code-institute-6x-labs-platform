{
  "toolbar_id": "main-toolbar-settings",
  "label": "Main Toolbar Settings",
  "description": "Horizontal toolbar below the editor menu with save, site selection tools, state management (Undo, Redo)",
  "state": {
    "currentSite": "site-1"
  },
  "sections": [
    {
      "group": "state-management",
      "align": "left",
      "label": "State Management",
      "items": [
        {
          "id": "save",
          "type": "button",
          "label": "",
          "icon": "bi-floppy-fill",
          "shortcut": "Ctrl+S",
          "tooltip": "Save the current changes"
        },
                {
          "id": "undo",
          "type": "button",
          "label": "Undo",
          "icon": "svg:undo",
          "shortcut": "Ctrl+Z",
          "tooltip": "Undo the last action",
          "enabled_when": "canUndo"
        },
        {
          "id": "redo",
          "type": "button",
          "label": "Redo",
          "icon": "svg:redo",
          "shortcut": "Ctrl+Y",
          "tooltip": "Redo the last undone action",
          "enabled_when": "canRedo"
        }
      ]
    },
    {
      "group": "site-selection",
      "align": "center",
      "label": "Site Selection",
      "items": [
        {
          "id": "site-dropdown",
          "type": "dropdown",
          "label": "Select Site",
          "defaultLabel": "Select Site",
          "icon": "bi-map",
          "tooltip": "Select the active site",
          "options": [
            { "value": "site-1", "label": "Site 1", "isSelected": true },
            { "value": "site-2", "label": "Site 2" },
            { "value": "site-3", "label": "Site 3" }
          ]
        },
        {
          "id": "previous-site",
          "type": "button",
          "label": "",
          "icon": "bi-arrow-left-circle",
          "tooltip": "Switch to the previous site"
        },
        {
          "id": "next-site",
          "type": "button",
          "label": "",
          "icon": "bi-arrow-right-circle",
          "tooltip": "Switch to the next site"
        }
      ]
    },
    {
      "group": "add-components",
      "align": "center",
      "label": "Add components",
      "items": [
        {
          "id": "add-components",
          "type": "dropdown",
          "label": "",
          "defaultLabel": "Add Components",
          "icon": "svg:add-component",
          "tooltip": "Add components to the map",
          "source": "/static/planting/data/components-toolbar.json",
          "options": []
        }
      ]
    }
  ]
}
