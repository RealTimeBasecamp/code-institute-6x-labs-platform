{
  "toolbar_id": "viewport-settings-toolbar",
  "label": "Viewport Settings",
  "description": "Horizontal toolbar above the map viewport with grid, snapping, camera and render settings",
  "state": {
    "activeTool": "select",
    "coordSystem": "world",
    "locationSnap": true,
    "locationSnapValue": 0,
    "rotationSnap": true,
    "rotationSnapValue": 10,
    "scaleSnap": true,
    "scaleSnapValue": 0.25,
    "cameraMode": "perspective",
    "cameraSpeed": 3.5,
    "renderMode": "lit"
  },
  "sections": [
    {
      "group": "transform-tools",
      "align": "left",
      "label": "Transform",
      "exclusive": true,
      "items": [
        { "id": "select", "type": "button", "icon": "bi-cursor", "shortcut": "Q", "tooltip": "Select", "isActive": true },
        { "id": "move", "type": "button", "icon": "bi-arrows-move", "shortcut": "W", "tooltip": "Move" },
        { "id": "rotate", "type": "button", "icon": "bi-arrow-repeat", "shortcut": "E", "tooltip": "Rotate" },
        { "id": "scale", "type": "button", "icon": "bi-arrows-angle-expand", "shortcut": "R", "tooltip": "Scale" }
      ]
    },
    {
      "group": "coord-system",
      "label": "Coordinate System",
      "items": [
        {
          "id": "coord-system",
          "type": "dropdown",
          "icon": "bi-globe",
          "tooltip": "Coordinate System",
          "showLabel": false,
          "options": [
            { "value": "world", "label": "World", "icon": "bi-globe", "isSelected": true },
            { "value": "local", "label": "Local", "icon": "bi-box" }
          ]
        }
      ]
    },
    {
      "group": "snapping-settings",
      "align": "center",
      "label": "Snapping",
      "items": [
        { "id": "location-snap", "type": "toggle", "icon": "bi-magnet", "tooltip": "Toggle Location Snapping", "default": true },
        {
          "id": "location-snap-value",
          "type": "value-dropdown",
          "tooltip": "Location Snap Value",
          "defaultValue": "0",
          "options": [
            { "value": "0", "label": "0 (Off)", "isSelected": true },
            { "value": "1", "label": "1" },
            { "value": "5", "label": "5" },
            { "value": "10", "label": "10" },
            { "value": "25", "label": "25" },
            { "value": "50", "label": "50" },
            { "value": "100", "label": "100" }
          ]
        },
        { "id": "rotation-snap", "type": "toggle", "icon": "bi-arrow-repeat", "tooltip": "Toggle Rotation Snapping", "default": true },
        {
          "id": "rotation-snap-value",
          "type": "value-dropdown",
          "tooltip": "Rotation Snap Value",
          "defaultValue": "10°",
          "options": [
            { "value": "5", "label": "5°" },
            { "value": "10", "label": "10°", "isSelected": true },
            { "value": "15", "label": "15°" },
            { "value": "30", "label": "30°" },
            { "value": "45", "label": "45°" },
            { "value": "90", "label": "90°" }
          ]
        },
        { "id": "scale-snap", "type": "toggle", "icon": "bi-aspect-ratio", "tooltip": "Toggle Scale Snapping", "default": true },
        {
          "id": "scale-snap-value",
          "type": "value-dropdown",
          "tooltip": "Scale Snap Value",
          "defaultValue": "0.25",
          "options": [
            { "value": "0.1", "label": "0.1" },
            { "value": "0.25", "label": "0.25", "isSelected": true },
            { "value": "0.5", "label": "0.5" },
            { "value": "1", "label": "1" }
          ]
        }
      ]
    },
    { "type": "spacer", "size": "flex", "align": "right" },
    {
      "group": "camera-settings",
      "align": "right",
      "label": "Camera",
      "items": [
        {
          "id": "camera-mode",
          "type": "dropdown",
          "icon": "bi-box",
          "label": "Perspective",
          "tooltip": "Camera Mode",
          "options": [
            { "type": "group", "label": "Projection Mode" },
            { "value": "perspective", "label": "Perspective", "icon": "bi-box", "isSelected": true },
            { "value": "orthographic", "label": "Orthographic", "icon": "bi-square" },
            { "value": "top", "label": "Top", "icon": "bi-arrow-down-square" },
            { "value": "front", "label": "Front", "icon": "bi-arrow-right-square" },
            { "value": "side", "label": "Side", "icon": "bi-arrow-up-square" }
          ]
        },
        {
          "id": "camera-speed",
          "type": "dropdown",
          "icon": "bi-speedometer2",
          "label": "3.5",
          "tooltip": "Camera Speed",
          "wide": true,
          "options": [
            { "type": "slider", "id": "camera-speed-slider", "label": "Speed", "min": 0.1, "max": 10, "step": 0.1, "default": 3.5 }
          ]
        }
      ]
    },
    {
      "group": "rendering-modes",
      "align": "right",
      "label": "Rendering",
      "items": [
        {
          "id": "render-mode",
          "type": "dropdown",
          "icon": "bi-circle-half",
          "label": "Lit",
          "tooltip": "Render Mode",
          "options": [
            { "type": "group", "label": "Map Style" },
            { "value": "lit", "label": "Lit", "icon": "bi-circle-half", "isSelected": true },
            { "value": "unlit", "label": "Unlit", "icon": "bi-circle" },
            { "type": "group", "label": "Debugging" },
            { "value": "wireframe", "label": "Wireframe", "icon": "bi-grid-3x3-gap" },
            { "value": "zones", "label": "Zones Only", "icon": "bi-layers" }
          ]
        },
        {
          "id": "show-menu",
          "type": "dropdown",
          "icon": "bi-eye",
          "tooltip": "Show",
          "showLabel": false,
          "wide": true,
          "options": [
            { "type": "group", "label": "Map Overlays" },
            { "type": "checkbox", "id": "show-grid", "label": "Grid", "default": true },
            { "type": "checkbox", "id": "show-labels", "label": "Labels", "default": true },
            { "type": "checkbox", "id": "show-coordinates", "label": "Coordinates", "default": true },
            { "type": "checkbox", "id": "show-stats", "label": "Statistics", "default": false },
            { "type": "checkbox", "id": "show-bounds", "label": "Bounds", "default": false },
            { "type": "separator" },
            { "type": "group", "label": "Map Layers" },
            { "type": "checkbox", "id": "show-echarts-data", "label": "Show ECharts Data", "default": true },
            { "type": "checkbox", "id": "show-3d-extrusions", "label": "Show 3D Extrusions", "default": true },
            { "type": "checkbox", "id": "show-map-shadows", "label": "Show Map Shadows", "default": true },
            { "type": "separator" },
            { "type": "number", "id": "terrain-scale", "label": "Terrain Scale", "min": 0, "max": 10, "step": 0.5, "default": 3.0 }
          ]
        },
        {
          "id": "viewport-settings",
          "type": "dropdown",
          "icon": "bi-gear",
          "tooltip": "Viewport Settings",
          "showLabel": false,
          "options": [
            { "action": "reset-camera", "label": "Reset Camera", "icon": "bi-house" },
            { "action": "frame-selected", "label": "Frame Selected", "icon": "bi-fullscreen" },
            { "type": "separator" },
            { "type": "checkbox", "id": "realtime-preview", "label": "Realtime Preview", "default": true },
            { "type": "checkbox", "id": "show-fps", "label": "Show FPS", "default": false }
          ]
        }
      ]
    },
    {
      "group": "multi-viewport",
      "align": "right",
      "label": "Multi Viewport",
      "items": [
        { "id": "toggle-split", "type": "button", "icon": "bi-layout-split", "tooltip": "Toggle Split View" }
      ]
    }
  ]
}
